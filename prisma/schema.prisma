generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  password      String
  phone         String?
  role          Role      @default(RECEPCION)
  isActive      Boolean   @default(true)
  photoUrl      String?
  refreshToken  String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ordersCreated  ServiceOrder[]       @relation("OrderCreatedBy")
  ordersAssigned ServiceOrder[]       @relation("OrderAssignedTo")
  diagnostics    Diagnostic[]
  statusChanges  OrderStatus[]
  inventoryMovements InventoryMovement[]
  notifications  Notification[]
  repairNotes    RepairNote[]

  @@map("usuarios")
}

enum Role {
  ADMIN
  RECEPCION
  TECNICO
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  document  String   @unique
  phone     String
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders ServiceOrder[]

  @@map("clientes")
}

model Equipment {
  id        Int      @id @default(autoincrement())
  brand     String
  model     String
  imei      String?  @unique
  serial    String?
  color     String?
  operator  String?
  accessories String? @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders ServiceOrder[]

  @@map("equipos")
}

model ServiceOrder {
  id              Int             @id @default(autoincrement())
  orderNumber     String          @unique
  reportedFault   String
  observations    String?
  physicalState   String?
  devicePassword  String?
  devicePattern   String?
  lockCode        String?
  lockCodeType    String?
  laborCost       Float?
  clientPhotoUrl  String?
  status          OrderStatusEnum @default(RECIBIDO)
  estimatedCost   Float?
  finalCost       Float?
  downPayment     Float?
  estimatedDate   DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  clientId   Int
  client     Client    @relation(fields: [clientId], references: [id])
  equipmentId Int
  equipment  Equipment @relation(fields: [equipmentId], references: [id])
  createdById Int
  createdBy  User      @relation("OrderCreatedBy", fields: [createdById], references: [id])
  assignedToId Int?
  assignedTo User?     @relation("OrderAssignedTo", fields: [assignedToId], references: [id])

  deviceTypeId  Int?
  deviceType    DeviceType?  @relation(fields: [deviceTypeId], references: [id])
  brandId       Int?
  brand         Brand?       @relation(fields: [brandId], references: [id])
  modelId       Int?
  model         DeviceModel? @relation(fields: [modelId], references: [id])
  serviceTypeId Int?
  serviceType   ServiceType? @relation(fields: [serviceTypeId], references: [id])

  diagnostics   Diagnostic[]
  photographs   Photograph[]
  signatures    Signature[]
  statusChanges OrderStatus[]
  pdfs          Pdf[]
  notifications Notification[]
  checklists    OrderChecklist[]
  parts         OrderPart[]
  repairNotes   RepairNote[]

  @@map("ordenes_servicio")
}

enum OrderStatusEnum {
  RECIBIDO
  DIAGNOSTICO
  ESPERANDO_APROBACION
  ESPERANDO_REPUESTO
  EN_REPARACION
  REPARADO
  LISTO_ENTREGA
  ENTREGADO
  CANCELADO
}

model OrderStatus {
  id        Int             @id @default(autoincrement())
  fromStatus OrderStatusEnum?
  toStatus  OrderStatusEnum
  reason    String?
  createdAt DateTime        @default(now())

  orderId   Int
  order     ServiceOrder @relation(fields: [orderId], references: [id])
  userId    Int
  user      User         @relation(fields: [userId], references: [id])

  @@map("orden_estados")
}

model Diagnostic {
  id              Int       @id @default(autoincrement())
  diagnosis       String
  neededParts     String?
  estimatedTime   String?
  estimatedCost   Float?
  approved        Boolean   @default(false)
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())

  orderId   Int
  order     ServiceOrder @relation(fields: [orderId], references: [id])
  userId    Int
  user      User         @relation(fields: [userId], references: [id])

  @@map("diagnosticos")
}

model Photograph {
  id        Int            @id @default(autoincrement())
  url       String
  type      PhotoType
  createdAt DateTime       @default(now())

  orderId   Int
  order     ServiceOrder   @relation(fields: [orderId], references: [id])

  @@map("fotografias")
}

enum PhotoType {
  FRONTAL
  TRASERA
  LATERAL
  PANTALLA
  DANO
  ENTREGA
}

model Signature {
  id        Int      @id @default(autoincrement())
  url       String
  type      SignatureType
  createdAt DateTime @default(now())

  orderId   Int
  order     ServiceOrder @relation(fields: [orderId], references: [id])

  @@map("firmas")
}

enum SignatureType {
  INGRESO
  ENTREGA
}

model Pdf {
  id        Int      @id @default(autoincrement())
  url       String
  type      PdfType
  createdAt DateTime @default(now())

  orderId   Int
  order     ServiceOrder @relation(fields: [orderId], references: [id])

  @@map("pdfs")
}

enum PdfType {
  INGRESO
  ENTREGA
}

model DeviceType {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  icon      String?
  createdAt DateTime      @default(now())

  models    DeviceModel[]
  orders    ServiceOrder[]

  @@map("tipos_dispositivo")
}

model Brand {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  createdAt DateTime      @default(now())

  models    DeviceModel[]
  orders    ServiceOrder[]

  @@map("marcas")
}

model DeviceModel {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  deviceTypeId Int
  deviceType   DeviceType @relation(fields: [deviceTypeId], references: [id])
  brandId      Int
  brand        Brand      @relation(fields: [brandId], references: [id])

  orders ServiceOrder[]

  @@unique([deviceTypeId, brandId, name])
  @@map("modelos_dispositivo")
}

model ServiceType {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  defaultCost Float?
  createdAt   DateTime      @default(now())

  orders      ServiceOrder[]

  @@map("tipos_servicio")
}

model OrderChecklist {
  id            Int      @id @default(autoincrement())
  componentName String
  checked       Boolean  @default(false)
  notTestable   Boolean  @default(false)
  createdAt     DateTime @default(now())

  orderId Int
  order   ServiceOrder @relation(fields: [orderId], references: [id])

  @@unique([orderId, componentName])
  @@map("checklist_orden")
}

model OrderPart {
  id        Int      @id @default(autoincrement())
  partName  String
  cost      Float
  createdAt DateTime @default(now())

  orderId Int
  order   ServiceOrder @relation(fields: [orderId], references: [id])

  @@map("piezas_orden")
}

model RepairNote {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  step      String   @default("reparacion")
  createdAt DateTime @default(now())

  orderId Int
  order   ServiceOrder @relation(fields: [orderId], references: [id])
  userId  Int
  user    User         @relation(fields: [userId], references: [id])

  @@map("notas_reparacion")
}

model InventoryItem {
  id          Int      @id @default(autoincrement())
  name        String
  reference   String?
  category    String
  description String?
  quality     String   @default("original")
  quantity    Int      @default(0)
  minStock    Int      @default(0)
  costPrice   Float?
  salePrice   Float?
  supplier    String?
  brand       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movements InventoryMovement[]

  @@map("inventario")
}

model InventoryMovement {
  id        Int            @id @default(autoincrement())
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime       @default(now())

  itemId    Int
  item      InventoryItem  @relation(fields: [itemId], references: [id])
  userId    Int
  user      User           @relation(fields: [userId], references: [id])

  @@map("movimientos_inventario")
}

enum MovementType {
  ENTRADA
  SALIDA
  AJUSTE
}

model CompanyConfig {
  id            Int      @id @default(autoincrement())
  companyName   String   @default("ServiCell")
  address       String?
  phone         String?
  email         String?
  logoUrl       String?
  pdfLogoUrl    String?
  terms         String?   @db.Text
  primaryColor  String   @default("#1976D2")
  smtpHost      String?
  smtpPort      Int?
  smtpUser      String?
  smtpPass      String?
  whatsappToken String?
  whatsappPhoneId String?
  updatedAt     DateTime @updatedAt

  @@map("configuracion_empresa")
}

model Notification {
  id        Int           @id @default(autoincrement())
  type      String
  message   String
  sent      Boolean       @default(false)
  sentAt    DateTime?
  createdAt DateTime      @default(now())

  orderId   Int
  order     ServiceOrder  @relation(fields: [orderId], references: [id])
  userId    Int?
  user      User?         @relation(fields: [userId], references: [id])

  @@map("notificaciones")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  userId    Int?

  @@map("auditoria")
}
